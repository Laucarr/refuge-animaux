<form method="post" action="{{ path('app_adopter_delete', {'id': adopter.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ adopter.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
