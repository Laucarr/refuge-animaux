{% extends 'base.html.twig' %}

{% block title %}Liste des adoptants
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="h3 mb-0">Liste des adoptants</h1>
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-striped table-hover align-middle mb-0">
					<thead class="table-dark">
						<th>Prénom</th>
						<th>Nom</th>
						<th>Email</th>
						<th>Actions</th>
					</thead>
				</tr>
			</thead>
			<tbody>
				{% for adopter in adopters %}
					<tr>
						<td>{{ adopter.firstName }}</td>
						<td>{{ adopter.lastName }}</td>
						<td>{{ adopter.email }}</td>
						<td class="text-nowrap">
							{% if is_granted('ADOPTER_VIEW', adopter) %}
								<a href="{{ path('app_adopter_show', {'id': adopter.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
							{% endif %}
							{% if is_granted('ADOPTER_EDIT', adopter) %}
								<a href="{{ path('app_adopter_edit', {'id': adopter.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
							{% endif %}
						</td>
					</tr>
				{% else %}
					<tr>
						<td colspan="4" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
					</tr>
				{% endfor %}
			</tbody>
		</tr>
	</tbody>
</tbody></table></div></div></div>{% endblock %}
