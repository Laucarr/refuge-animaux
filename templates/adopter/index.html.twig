{% extends 'base.html.twig' %}

{% block title %}Adopter index{% endblock %}

{% block body %}
    <h1>Adopter index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>FirstName</th>
                <th>LastName</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Address</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for adopter in adopters %}
            <tr>
                <td>{{ adopter.id }}</td>
                <td>{{ adopter.firstName }}</td>
                <td>{{ adopter.lastName }}</td>
                <td>{{ adopter.email }}</td>
                <td>{{ adopter.phone }}</td>
                <td>{{ adopter.address }}</td>
                <td>
                    <a href="{{ path('app_adopter_show', {'id': adopter.id}) }}">show</a>
                    <a href="{{ path('app_adopter_edit', {'id': adopter.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_adopter_new') }}">Create new</a>
{% endblock %}
