{% extends 'base.html.twig' %}

{% block title %}Adoptant
{% endblock %}

{% block body %}
	<div class="row justify-content-center">
		<div class="col-lg-8">
			<div class="card shadow-sm">
				<div class="card-header bg-light">
					<h1 class="mb-0 fw-bold">Adoptant</h1>
				</div>
				<div class="card-body">
					<dl class="row mb-0">
						<dt class="col-sm-4 text-muted">Id</dt>
						<dd class="col-sm-8">{{ adopter.id }}</dd>

						<dt class="col-sm-4 text-muted">Prénom</dt>
						<dd class="col-sm-8">{{ adopter.firstName }}</dd>

						<dt class="col-sm-4 text-muted">Nom</dt>
						<dd class="col-sm-8">{{ adopter.lastName }}</dd>

						<dt class="col-sm-4 text-muted">Email</dt>
						<dd class="col-sm-8">{{ adopter.email }}</dd>

						<dt class="col-sm-4 text-muted">Téléphone</dt>
						<dd class="col-sm-8">{{ adopter.phone }}</dd>

						<dt class="col-sm-4 text-muted">Adresse</dt>
						<dd class="col-sm-8 mb-0">{{ adopter.address }}</dd>
					</dl>
				</div>
				<div class="card-footer d-flex justify-content-between align-items-center">
					<a href="{{ path('app_adopter_index') }}" class="btn btn-outline-secondary">← Retour à la liste</a>
					<div class="d-flex gap-2">
						<a href="{{ path('app_adopter_edit', {'id': adopter.id}) }}" class="btn btn-warning">Modifier</a>
						{{ include('adopter/_delete_form.html.twig') }}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
