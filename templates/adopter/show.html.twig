{% extends 'base.html.twig' %}

{% block title %}Adoptant{% endblock %}

{% block body %}
    <h1>Adoptant</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ adopter.id }}</td>
            </tr>
            <tr>
                <th>Prénom</th>
                <td>{{ adopter.firstName }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ adopter.lastName }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ adopter.email }}</td>
            </tr>
            <tr>
                <th>Téléphone</th>
                <td>{{ adopter.phone }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ adopter.address }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_adopter_index') }}">Retour à la liste</a>

    <a href="{{ path('app_adopter_edit', {'id': adopter.id}) }}">Modifier</a>

    {{ include('adopter/_delete_form.html.twig') }}
{% endblock %}
