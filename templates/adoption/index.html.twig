{% extends 'base.html.twig' %}

{% block title %}Liste des adoptions
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="h3 mb-0">Liste des adoptions</h1>
		{% if is_granted('ADOPTION_CREATE') %}
			<a href="{{ path('app_adoption_new') }}" class="btn btn-success">+ Créer</a>
		{% endif %}
	</div>

	{{ component('AdoptionSearch', { 'userShelterIds': shelterIds }) }}
{% endblock %}
