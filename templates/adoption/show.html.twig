{% extends 'base.html.twig' %}

{% block title %}Adoption
{% endblock %}

{% block body %}
	<div class="row justify-content-center">
		<div class="col-lg-8">
			<div class="card shadow-sm">
				<div class="card-header bg-light">
					<h1 class="mb-0 fw-bold">Adoption</h1>
				</div>
				<div class="card-body">
					<dl class="row mb-0">
						<dt class="col-sm-4 text-muted">Id</dt>
						<dd class="col-sm-8">{{ adoption.id }}</dd>

						<dt class="col-sm-4 text-muted">Date</dt>
						<dd class="col-sm-8">{{ adoption.date ? adoption.date|date('d/m/Y') : '' }}</dd>

						<dt class="col-sm-4 text-muted">Statut</dt>
						<dd class="col-sm-8">
							<span class="badge bg-secondary">{{ adoption.status }}</span>
						</dd>

						<dt class="col-sm-4 text-muted">Adoptant</dt>
						<dd class="col-sm-8">{{ adoption.adopter.firstName }}
							{{ adoption.adopter.lastName }}</dd>

						<dt class="col-sm-4 text-muted">Animal</dt>
						<dd class="col-sm-8">{{ adoption.animal.name }}</dd>

						<dt class="col-sm-4 text-muted">Refuge</dt>
						<dd class="col-sm-8">{{ adoption.animal.shelter.name }}</dd>

						<dt class="col-sm-4 text-muted">Notes</dt>
						<dd class="col-sm-8 mb-0">{{ adoption.notes }}</dd>
					</dl>
				</div>
				<div class="card-footer d-flex justify-content-between align-items-center">
					<a href="{{ path('app_adoption_index') }}" class="btn btn-outline-secondary">← Retour à la liste</a>
					<div class="d-flex gap-2">
						<a href="{{ path('app_adoption_edit', {'id': adoption.id}) }}" class="btn btn-warning">Modifier</a>
						{{ include('adoption/_delete_form.html.twig') }}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
