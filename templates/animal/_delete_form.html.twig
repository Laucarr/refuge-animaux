<form method="post" action="{{ path('app_animal_delete', {'id': animal.id}) }}" onsubmit="return confirm('{{ animal.adoptions is not empty ? 'Attention ! Cet animal a ' ~ animal.adoptions|length ~ ' adoption(s) qui seront aussi supprimées. Confirmer ?' : 'Êtes-vous sûr de vouloir supprimer cet animal ?' }}');">
	<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ animal.id) }}">
	<button class="btn btn-danger">Supprimer</button>
</form>
