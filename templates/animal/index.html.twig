{% extends 'base.html.twig' %}

{% block title %}Liste des animaux{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">Liste des animaux</h1>
        <a href="{{ path('app_animal_new') }}" class="btn btn-success">+ Créer</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Id</th>
                            <th>Nom</th>
                            <th>Âge</th>
                            <th>Espèce</th>
                            <th>Statut</th>
                            <th>Description</th>
                            <th>Refuge</th>
                            <th>Soignants</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for animal in animals %}
                            <tr>
                                <td>{{ animal.id }}</td>
                                <td>{{ animal.name }}</td>
                                <td>{{ animal.age }}</td>
                                <td>{{ animal.species.name }}</td>
                                <td><span class="badge bg-secondary">{{ animal.status }}</span></td>
                                <td>{{ animal.description }}</td>
                                <td>{{ animal.shelter.name }}</td>
                                <td>
                                    {% for caretaker in animal.caretaker %}
                                        <span class="badge bg-light text-dark border">{{ caretaker.firstName }} {{ caretaker.lastName }}</span>
                                    {% endfor %}
                                </td>
                                <td class="text-nowrap">
                                    <a href="{{ path('app_animal_show', {'id': animal.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
                                    <a href="{{ path('app_animal_edit', {'id': animal.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
