{% extends 'base.html.twig' %}

{% block title %}Animal index
{% endblock %}

{% block body %}
	<h1>Animal index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Name</th>
				<th>Age</th>
				<th>Status</th>
				<th>Description</th>
				<th>Shelter</th>
				<th>Caretakers</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for animal in animals %}
				<tr>
					<td>{{ animal.id }}</td>
					<td>{{ animal.name }}</td>
					<td>{{ animal.age }}</td>
					<td>{{ animal.status }}</td>
					<td>{{ animal.description }}</td>
					<td>{{ animal.shelter.name }}</td>
					<td>
						<ul>
							{% for caretaker in animal.caretaker %}
								<li>{{ caretaker.lastName }}</li>
							{% endfor %}
						</ul>
					</td>
					<td>
						<a href="{{ path('app_animal_show', {'id': animal.id}) }}">show</a>
						<a href="{{ path('app_animal_edit', {'id': animal.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="8">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('app_animal_new') }}">Create new</a>
{% endblock %}
