{% extends 'base.html.twig' %}

{% block title %}Liste des animaux{% endblock %}

{% block body %}
	<h1>Liste des animaux</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Nom</th>
				<th>Âge</th>
				<th>Espèce</th>
				<th>Statut</th>
				<th>Description</th>
				<th>Refuge</th>
				<th>Soignants</th>
				<th>Actions</th>
			</tr>
		</thead>
		<tbody>
			{% for animal in animals %}
				<tr>
					<td>{{ animal.id }}</td>
					<td>{{ animal.name }}</td>
					<td>{{ animal.age }}</td>
					<td>{{ animal.species.name }}</td>
					<td>{{ animal.status }}</td>
					<td>{{ animal.description }}</td>
					<td>{{ animal.shelter.name }}</td>
					<td>
						<ul>
							{% for caretaker in animal.caretaker %}
								<li>{{ caretaker.firstName }}
									{{ caretaker.lastName }}</li>
							{% endfor %}
						</ul>
					</td>
					<td>
						<a href="{{ path('app_animal_show', {'id': animal.id}) }}">Voir</a>
						<a href="{{ path('app_animal_edit', {'id': animal.id}) }}">Modifier</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="9">Aucun enregistrement trouvé</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('app_animal_new') }}">Créer</a>
{% endblock %}
