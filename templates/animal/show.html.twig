{% extends 'base.html.twig' %}

{% block title %}Animal
{% endblock %}

{% block body %}
	<h1>Animal</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ animal.id }}</td>
			</tr>
			<tr>
				<th>Name</th>
				<td>{{ animal.name }}</td>
			</tr>
			<tr>
				<th>Age</th>
				<td>{{ animal.age }}</td>
			</tr>
			<tr>
				<th>Status</th>
				<td>{{ animal.status }}</td>
			</tr>
			<tr>
				<th>Description</th>
				<td>{{ animal.description }}</td>
			</tr>
			<tr>
				<th>Shelter</th>
				<td>{{ animal.shelter.name }}</td>
			</tr>
			<tr>
				<th>Caretakers</th>
				<td>
					<ul>
						{% for caretaker in animal.caretaker %}
							<li>{{ caretaker.lastName }}</li>
						{% endfor %}
					</ul>
				</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('app_animal_index') }}">back to list</a>

	<a href="{{ path('app_animal_edit', {'id': animal.id}) }}">edit</a>

	{{ include('animal/_delete_form.html.twig') }}
{% endblock %}
