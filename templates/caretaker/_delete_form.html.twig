<form method="post" action="{{ path('app_caretaker_delete', {'id': caretaker.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ caretaker.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
