{% extends 'base.html.twig' %}

{% block title %}Liste des soignants
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="h3 mb-0">Liste des soignants</h1>
		{% if is_granted('CARETAKER_CREATE') %}
			<a href="{{ path('app_caretaker_new') }}" class="btn btn-success">+ Créer</a>
		{% endif %}
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-striped table-hover align-middle mb-0">
					<thead class="table-dark">
						<tr>
							<th>Prénom</th>
							<th>Nom</th>
							<th>Email</th>
							<th>Téléphone</th>
							<th>Refuges</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for caretaker in caretakers %}
							<tr>
								<td>{{ caretaker.firstName }}</td>
								<td>{{ caretaker.lastName }}</td>
								<td>{{ caretaker.email }}</td>
								<td>{{ caretaker.phone }}</td>
								<td>
									{% for shelter in caretaker.shelter %}
										<a href="{{ path('app_shelter_show', {'id': shelter.id}) }}">
											{{ shelter.name }}
										</a>
									{% endfor %}
								</td>
								<td class="text-nowrap">
									{% if is_granted('CARETAKER_VIEW', caretaker) %}
										<a href="{{ path('app_caretaker_show', {'id': caretaker.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
									{% endif %}
									{% if is_granted('CARETAKER_EDIT', caretaker) %}
										<a href="{{ path('app_caretaker_edit', {'id': caretaker.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
									{% endif %}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="6" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
