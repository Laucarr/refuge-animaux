{% extends 'base.html.twig' %}

{% block title %}Soignant
{% endblock %}

{% block body %}
	<div class="row justify-content-center">
		<div class="col-lg-8">
			<div class="card shadow-sm">
				<div class="card-header bg-light">
					<h1 class="mb-0 fw-bold">Soignant</h1>
				</div>
				<div class="card-body">
					<dl class="row mb-0">
						<dt class="col-sm-4 text-muted">Id</dt>
						<dd class="col-sm-8">{{ caretaker.id }}</dd>

						<dt class="col-sm-4 text-muted">Prénom</dt>
						<dd class="col-sm-8">{{ caretaker.firstName }}</dd>

						<dt class="col-sm-4 text-muted">Nom</dt>
						<dd class="col-sm-8">{{ caretaker.lastName }}</dd>

						<dt class="col-sm-4 text-muted">Email</dt>
						<dd class="col-sm-8">{{ caretaker.email }}</dd>

						<dt class="col-sm-4 text-muted">Téléphone</dt>
						<dd class="col-sm-8">{{ caretaker.phone }}</dd>

						<dt class="col-sm-4 text-muted">Jours de travail</dt>
						<dd class="col-sm-8">
							{% if caretaker.workDays %}
								{% for day in caretaker.workDays %}
									<span class="badge bg-primary">{{ day }}</span>
								{% endfor %}
							{% endif %}
						</dd>

						<dt class="col-sm-4 text-muted">Heure de début</dt>
						<dd class="col-sm-8">{{ caretaker.startTime ? caretaker.startTime|date('H:i') : '—' }}</dd>

						<dt class="col-sm-4 text-muted">Heure de fin</dt>
						<dd class="col-sm-8">{{ caretaker.endTime ? caretaker.endTime|date('H:i') : '—' }}</dd>

						<dt class="col-sm-4 text-muted">Animaux</dt>
						<dd class="col-sm-8">
							{% for animal in caretaker.animals %}
								<a href="{{ path('app_animal_show', {'id': animal.id}) }}" class="badge bg-light text-dark border text-decoration-none">
									{{ animal.name }}
								</a>
							{% else %}
								<span class="text-muted">—</span>
							{% endfor %}
						</dd>

						<dt class="col-sm-4 text-muted">Refuges</dt>
						<dd class="col-sm-8 mb-0">
							{% for shelter in caretaker.shelter %}
								<a href="{{ path('app_shelter_show', {'id': shelter.id}) }}">
									{{ shelter.name }}
								</a>
							{% endfor %}
						</dd>
					</dl>
				</div>
				<div class="card-footer d-flex justify-content-between align-items-center">
					<a href="{{ path('app_caretaker_index') }}" class="btn btn-outline-secondary">← Retour à la liste</a>
					<div class="d-flex gap-2">
						{% if is_granted('CARETAKER_EDIT', caretaker) %}
							<a href="{{ path('app_caretaker_edit', {'id': caretaker.id}) }}" class="btn btn-warning">Modifier</a>
						{% endif %}
						{% if is_granted('CARETAKER_DELETE', caretaker) %}
							{{ include('caretaker/_delete_form.html.twig') }}
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
