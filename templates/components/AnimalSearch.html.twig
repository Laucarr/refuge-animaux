<div
	{{ attributes }}>
	{# Filtres #}
	<div class="row mb-3">
		<div class="col">
			<input type="text" class="form-control" placeholder="Rechercher par nom..." data-model="name">
		</div>
		<div class="col">
			<select class="form-select" data-model="status">
				<option value="">Tous les statuts</option>
				<option value="disponible">Disponible</option>
				<option value="adopté">Adopté</option>
				<option value="en cours d'adoption">En cours d'adoption</option>
			</select>
		</div>
		<div class="col">
			<select class="form-select" data-model="speciesId">
				<option value="0">Toutes les espèces</option>
				{% for species in this.species %}
					<option value="{{ species.id }}">{{ species.name }}</option>
				{% endfor %}
			</select>
		</div>
		<div class="col">
			<select class="form-select" data-model="shelterId">
				<option value="0">Tous les refuges</option>
				{% for shelter in this.shelters %}
					<option value="{{ shelter.id }}">{{ shelter.name }}</option>
				{% endfor %}
			</select>
		</div>
	</div>
	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-striped table-hover align-middle mb-0">
					<thead class="table-dark">
						<tr>
							<th>Id</th>
							<th>Nom</th>
							<th>Âge</th>
							<th>Espèce</th>
							<th>Statut</th>
							<th>Description</th>
							<th>Refuge</th>
							<th>Soignants</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for animal in this.animals %}
							<tr>
								<td>{{ animal.id }}</td>
								<td>{{ animal.name }}</td>
								<td>{{ animal.age }}</td>
								<td>{{ animal.species.name }}</td>
								<td>
									<span class="badge bg-secondary">{{ animal.status }}</span>
								</td>
								<td>{{ animal.description }}</td>
								<td>{{ animal.shelter.name }}</td>
								<td>
									{% for caretaker in animal.caretaker %}
										<span class="badge bg-light text-dark border">{{ caretaker.firstName }}
											{{ caretaker.lastName }}</span>
									{% endfor %}
								</td>
								<td class="text-nowrap">
									<a href="{{ path('app_animal_show', {'id': animal.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
									<a href="{{ path('app_animal_edit', {'id': animal.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="9" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>
