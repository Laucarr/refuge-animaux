<form method="post" action="{{ path('app_shelter_delete', {'id': shelter.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ shelter.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
