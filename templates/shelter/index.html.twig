{% extends 'base.html.twig' %}

{% block title %}Liste des refuges
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="h3 mb-0">Liste des refuges</h1>
		{# Seul ROLE_ADMIN peut créer #}
		{% if is_granted('ROLE_ADMIN') %}
			<a href="{{ path('app_shelter_new') }}" class="btn btn-success">+ Créer</a>
		{% endif %}
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-striped table-hover align-middle mb-0">
					<thead class="table-dark">
						<tr>
							<th>Id</th>
							<th>Nom</th>
							<th>Adresse</th>
							<th>Téléphone</th>
							<th>Email</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for shelter in shelters %}
							<tr>
								<td>{{ shelter.id }}</td>
								<td>{{ shelter.name }}</td>
								<td>{{ shelter.address }}</td>
								<td>{{ shelter.phone }}</td>
								<td>{{ shelter.email }}</td>
								<td
									class="text-nowrap">
									{# Voir : seulement si owner #}
									{% if is_granted('SHELTER_VIEW', shelter) %}
										<a href="{{ path('app_shelter_show', {'id': shelter.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
									{% endif %}
									{# Modifier : seulement si owner #}
									{% if is_granted('SHELTER_EDIT', shelter) %}
										<a href="{{ path('app_shelter_edit', {'id': shelter.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
									{% endif %}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="8" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
