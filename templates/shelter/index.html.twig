{% extends 'base.html.twig' %}

{% block title %}Shelter index
{% endblock %}

{% block body %}
	<h1>Shelter index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Name</th>
				<th>Address</th>
				<th>Phone</th>
				<th>Email</th>
				<th>Capacity</th>
				<th>Caretakers</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for shelter in shelters %}
				<tr>
					<td>{{ shelter.id }}</td>
					<td>{{ shelter.name }}</td>
					<td>{{ shelter.address }}</td>
					<td>{{ shelter.phone }}</td>
					<td>{{ shelter.email }}</td>
					<td>{{ shelter.capacity }}</td>
					<td>
						<ul>
							{% for caretaker in shelter.caretakers %}
								<li>{{ caretaker.lastName }}</li>
							{% endfor %}
						</ul>
					</td>
					<td>
						<a href="{{ path('app_shelter_show', {'id': shelter.id}) }}">show</a>
						<a href="{{ path('app_shelter_edit', {'id': shelter.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="7">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('app_shelter_new') }}">Create new</a>
{% endblock %}
