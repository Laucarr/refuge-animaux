{% extends 'base.html.twig' %}

{% block title %}Shelter
{% endblock %}

{% block body %}
	<h1>Shelter</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ shelter.id }}</td>
			</tr>
			<tr>
				<th>Name</th>
				<td>{{ shelter.name }}</td>
			</tr>
			<tr>
				<th>Address</th>
				<td>{{ shelter.address }}</td>
			</tr>
			<tr>
				<th>Phone</th>
				<td>{{ shelter.phone }}</td>
			</tr>
			<tr>
				<th>Email</th>
				<td>{{ shelter.email }}</td>
			</tr>
			<tr>
				<th>Capacity</th>
				<td>{{ shelter.capacity }}</td>
			</tr>
			<tr>
				<th>Caretakers</th>
				<td>
					<ul>
						{% for caretaker in shelter.caretakers %}
							<li>{{ caretaker.lastName }}</li>
						{% endfor %}
					</ul>
				</td>
			</tr>
		</tbody>
	</td>
</tr></tbody></table><a href="{{ path('app_shelter_index') }}">back to list</a><a href="{{ path('app_shelter_edit', {'id': shelter.id}) }}">edit</a>{{ include('shelter/_delete_form.html.twig') }}{% endblock %}
