{% extends 'base.html.twig' %}

{% block title %}Refuge
{% endblock %}

{% block body %}
	<div class="row justify-content-center">
		<div class="col-lg-8">
			<div class="card shadow-sm">
				<div class="card-header bg-light">
					<h1 class="mb-0 fw-bold">Refuge</h1>
				</div>
				<div class="card-body">
					<dl class="row mb-0">
						<dt class="col-sm-4 text-muted">Id</dt>
						<dd class="col-sm-8">{{ shelter.id }}</dd>

						<dt class="col-sm-4 text-muted">Nom</dt>
						<dd class="col-sm-8">{{ shelter.name }}</dd>

						<dt class="col-sm-4 text-muted">Adresse</dt>
						<dd class="col-sm-8">{{ shelter.address }}</dd>

						<dt class="col-sm-4 text-muted">Téléphone</dt>
						<dd class="col-sm-8">{{ shelter.phone }}</dd>

						<dt class="col-sm-4 text-muted">Email</dt>
						<dd class="col-sm-8">{{ shelter.email }}</dd>

						<dt class="col-sm-4 text-muted">Capacité</dt>
						<dd class="col-sm-8">{{ shelter.capacity }}</dd>

						<dt class="col-sm-4 text-muted">Soignants</dt>
						<dd class="col-sm-8 mb-0">
							{% for caretaker in shelter.caretakers %}
								<a href="{{ path('app_caretaker_show', {'id': caretaker.id}) }}" class="badge bg-light text-dark border text-decoration-none">
									{{ caretaker.firstName }}
									{{ caretaker.lastName }}
								</a>
							{% else %}
								<span class="text-muted">—</span>
							{% endfor %}
						</dd>

						<dt class="col-sm-4 text-muted">Animaux</dt>
						<dd class="col-sm-8 mb-0">
							{% for animal in shelter.animals %}
								<a href="{{ path('app_animal_show', {'id': animal.id}) }}" class="badge bg-light text-dark border text-decoration-none">
									{{ animal.name }}
								</a>
							{% else %}
								<span class="text-muted">—</span>
							{% endfor %}
						</dd>
					</dl>
				</div>
				<div class="card-footer d-flex justify-content-between align-items-center">
					<a href="{{ path('app_shelter_index') }}" class="btn btn-outline-secondary">← Retour à la liste</a>
					<div class="d-flex gap-2">
						<a href="{{ path('app_shelter_edit', {'id': shelter.id}) }}" class="btn btn-warning">Modifier</a>
						{{ include('shelter/_delete_form.html.twig') }}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
