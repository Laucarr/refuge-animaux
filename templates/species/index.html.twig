{% extends 'base.html.twig' %}

{% block title %}Liste des espèces
{% endblock %}

{% block body %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="h3 mb-0">Liste des espèces</h1>
		{% if is_granted('ROLE_ADMIN') %}
			<a href="{{ path('app_species_new') }}" class="btn btn-success">+ Créer</a>
		{% endif %}
	</div>

	<div class="card shadow-sm">
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table table-striped table-hover align-middle mb-0">
					<thead class="table-dark">
						<tr>
							<th>Nom</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{% for species in species %}
							<tr>
								<td>{{ species.name }}</td>
								<td class="text-nowrap">
									<a href="{{ path('app_species_show', {'id': species.id}) }}" class="btn btn-sm btn-outline-primary">Voir</a>
									{% if is_granted('ROLE_ADMIN') %}
										<a href="{{ path('app_species_edit', {'id': species.id}) }}" class="btn btn-sm btn-outline-warning">Modifier</a>
									{% endif %}
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="2" class="text-center text-muted py-4">Aucun enregistrement trouvé</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</div>
{% endblock %}
